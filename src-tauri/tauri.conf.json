{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MapX",
  "version": "0.1.4",
  "identifier": "com.qinshan.mapx",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MapX",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyNUJFQURCQzk1NURENgpSV1RXWFpXOHJiNGxBclk1REZ4cVJvYlYrbVN5VW8zOVBNQ2RXTmt2MzJ3cU9oNmZPOUZFVFMzUgo=",
      "endpoints": [
        "https://github.com/QinshanSun/mapx/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
